{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@tsx/flutter",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "bin/**/*", "scripts/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
