{
  "name": "@tsx/flutter",
  "version": "0.1.0",
  "type": "module",
  "bin": { "fsx": "./dist/bin/fsx.js" },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/src/jsx-runtime.js",
      "types": "./dist/src/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/src/jsx-dev-runtime.js",
      "types": "./dist/src/jsx-dev-runtime.d.ts"
    }
  },
  "scripts": {
    "define": "bun scripts/parse-flutter-docs.ts && bun scripts/generate-types.ts",
    "build": "bun run build:clean && bun run build:types && bun run build:bundle",
    "build:clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:bundle": "bun build ./bin/fsx.ts ./src/index.ts ./src/jsx-runtime.ts ./src/jsx-dev-runtime.ts --outdir dist --target bun --format esm --splitting",
    "dev": "bun run --watch bin/fsx.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "@clack/prompts": "^0.9.0",
    "chokidar": "^3.6.0",
    "defu": "^6.1.4",
    "smol-toml": "^1.3.1",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
