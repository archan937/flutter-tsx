{
  "name": "flutter-tsx",
  "version": "0.1.0",
  "description": "Write Flutter apps in TypeScript + JSX with full IDE autocomplete — transpiles to idiomatic Dart.",
  "keywords": [
    "flutter",
    "dart",
    "tsx",
    "jsx",
    "typescript",
    "cross-platform",
    "transpiler",
    "fsx",
    "bun"
  ],
  "homepage": "https://github.com/archan937/flutter-tsx#readme",
  "bugs": {
    "url": "https://github.com/archan937/flutter-tsx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archan937/flutter-tsx.git"
  },
  "license": "MIT",
  "author": "Paul Engel",
  "type": "module",
  "bin": {
    "fsx": "./dist/bin/fsx.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/src/jsx-runtime.js",
      "types": "./dist/src/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/src/jsx-dev-runtime.js",
      "types": "./dist/src/jsx-dev-runtime.d.ts"
    },
    "./config": {
      "import": "./dist/src/config.js",
      "types": "./dist/src/config.d.ts"
    }
  },
  "scripts": {
    "define": "bun scripts/define/index.ts",
    "docs": "bun scripts/generate-api-reference.ts",
    "build": "bun run build:clean && bun run build:types && bun run build:bundle",
    "build:clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "bun build ./bin/fsx.ts ./src/index.ts ./src/jsx-runtime.ts ./src/jsx-dev-runtime.ts ./src/config.ts --outdir dist --target bun --format esm --splitting",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "bun test",
    "test:coverage": "bun scripts/check-coverage.ts",
    "quality": "bun run typecheck && bun run format && bun run lint && bun run test:coverage",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "@clack/prompts": "^0.9.0",
    "chokidar": "^3.6.0",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/bun": "^1.2.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.10.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.8.0"
  }
}
